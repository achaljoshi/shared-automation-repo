# Commit: project-level IDE config (SDK, compiler, run configs, Cucumber glue)
# Ignore: user-specific workspace state

# User workspace (opened files, breakpoints, local history — different per developer)
workspace.xml
tasks.xml
usage.statistics.xml
dictionaries/
shelf/

# Sensitive or machine-specific
httpRequests/
dataSources/
dataSources.local.xml
*.iws
*.iml

# Dynamic indexes — regenerated on open, never commit
caches/
libraries/
modules.xml

# Temp backup files some editors create
*.xml~
*.xml.bak
